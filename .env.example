APP_ENV=development
PORT=4000
BREVYN_CLOUD_IMAGE=ghcr.io/koiai777/brevyn-cloud:latest
POSTGRES_PASSWORD=brevyn
DATABASE_URL=postgres://brevyn:brevyn@postgres:5432/brevyn_cloud?sslmode=disable
REDIS_URL=redis://redis:6379/0
POSTGRES_MAX_CONNS=30
POSTGRES_MIN_CONNS=2
# Development defaults to true. Production must keep this false and run brevyn-migrate first.
MIGRATE_ON_STARTUP=
BACKUP_DIR=./backups/postgres
BACKUP_RETENTION_DAYS=14
# Destructive admin restore stays disabled unless explicitly enabled.
ALLOW_ADMIN_DB_RESTORE=false

APP_BASE_URL=http://127.0.0.1:4000
ADMIN_BASE_URL=http://127.0.0.1:4000/admin
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
ADMIN_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
TRUSTED_PROXIES=
ADMIN_WEB_DIR=./web/admin/dist

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
SESSION_SECRET=change-me-session
ENCRYPTION_KEY=change-me-32-byte-secret
ADMIN_SEED_EMAIL=owner@brevyn.local
ADMIN_SEED_PASSWORD=Brevyn@Admin2026

SUB2API_BASE_URL=http://127.0.0.1:8080
SUB2API_ADMIN_API_KEY=
SUB2API_ADMIN_EMAIL=
SUB2API_ADMIN_PASSWORD=
# Optional bootstrap fallback only. The product default group is set in the admin Settings page.
SUB2API_DEFAULT_GROUP_ID=0
REGISTER_PROVISION_CONCURRENCY=10
SUB2API_OPERATION_CONCURRENCY=5
SUB2API_OPERATION_BATCH_SIZE=10
SUB2API_OPERATION_INTERVAL=10s
SUB2API_OPERATION_STALE_TIMEOUT=5m

OFFICIAL_PROVIDER_BASE_URL=https://api.brevyn.org/v1
OFFICIAL_PROVIDER_DEFAULT_MODEL=
DEVICE_SOFT_LIMIT=3
